# ============================================================
# Autonomous Content Bridge — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- Kimi K2.5 (Moonshot AI) ---
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# --- Hermes Agent (via OpenRouter or self-hosted) ---
HERMES_API_KEY=your_openrouter_api_key_here
HERMES_BASE_URL=https://openrouter.ai/api/v1
HERMES_MODEL=nousresearch/hermes-3-llama-3.1-405b

# --- X / Twitter API ---
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
X_BEARER_TOKEN=your_x_bearer_token

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=/opt/content-bridge/data
LOG_LEVEL=INFO

# --- Whisper (local transcription) ---
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large-v3
# 'base' recommended for speed vs accuracy balance on VPS
